# ─────────────────────────────────────────────────────────────
# Brew Recipes — Environment variables
# Copy this file to `.env` (local) and set the real values.
# On Vercel, add these under Project → Settings → Environment Variables.
# Never commit real secrets — `.env` and `.env*.local` are gitignored.
# ─────────────────────────────────────────────────────────────

# PostgreSQL (Supabase / Neon). Prisma uses two URLs:
#   DATABASE_URL = pooled connection used by the running app (Supabase port 6543).
#   DIRECT_URL   = direct connection used for migrations & seeding (Supabase port 5432).
# For a non-pooled provider (e.g. Neon single URL) set both to the same value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Supabase auth (public — exposed to the browser, safe to be public keys only).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"

# Public site URL — used for SEO metadata (Open Graph, canonical URLs).
# Set to your deployed domain in production; defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Admin panel gate — you are the ONLY person who can manage content/images.
# ADMIN_PASSWORD: the password used to sign in at /admin/login.
#   Required in production. In local dev it defaults to "brew-admin" if unset.
# ADMIN_SESSION_SECRET: random string used to sign the admin session cookie.
#   Set any long random value in production.
ADMIN_PASSWORD="change-me-to-a-strong-password"
ADMIN_SESSION_SECRET="a-long-random-string-for-signing-the-admin-cookie"
